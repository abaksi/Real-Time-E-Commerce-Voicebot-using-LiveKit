# eCommerce VoiceBot Configuration
# Copy this file to .env and update with your settings

# ============================================
# Backend Server Configuration
# ============================================
BACKEND_HOST=127.0.0.1
BACKEND_PORT=5001
RELOAD=true

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_HOST=localhost
FRONTEND_PORT=8000

# ============================================
# Audio Recording Configuration
# ============================================
# Maximum recording duration in seconds (default: 30)
MAX_RECORDING_DURATION=30

# ============================================
# Speech-to-Text (STT) Configuration
# ============================================
# Options: tiny, base, small, medium, large
# tiny = fastest (39M), base = balanced (140M), small = slower (466M)
# Models are cached in ~/.cache/whisper/ - downloaded once, reused thereafter
WHISPER_MODEL=base
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
STT_MIN_SAMPLES=6000
STT_NO_SPEECH_THRESHOLD=0.7
STT_VAD_FILTER=true
STT_BEAM_SIZE=2

# Enable LiveKit transcription (currently false - use local Whisper)
USE_LIVEKIT_TRANSCRIPTION=false

# Disable fallback demo phrases - use real Whisper transcription only
# Set to false to always use Whisper (no demo fallbacks)
USE_DEMO_FALLBACK=false

# ============================================
# Language Model (LLM) Configuration
# ============================================


# OpenAI API key for GPT (leave blank to use ollama local LLM instead)
OPENAI_API_KEY= 
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=80
# Control response length
OPENAI_TIMEOUT_SECONDS=30       # allow enough time for cloud response
OPENAI_RETRIES=3                # retry on transient failures
OPENAI_RETRY_BACKOFF=2.0        # seconds to wait between retries

# Local Ollama command
OLLAMA_CMD=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL= llama3.2:1b
OLLAMA_TIMEOUT_SECONDS=45
OLLAMA_RETRIES=3
OLLAMA_RETRY_BACKOFF_SECONDS=2.0
OLLAMA_NUM_PREDICT=80
OLLAMA_TEMPERATURE=0.1
PIPELINE_LLM_TIMEOUT_SECONDS=90
EDGE_TTS_VOICE=en-US-JennyNeural
EDGE_TTS_RATE=+20%
EDGE_TTS_VOLUME=+0%
LLM_MAX_TOKENS=300
LLM_TEMPERATURE=0.2

# ============================================
# Data Files
# ============================================
PRODUCT_DATASET_PATH=data/product-dataset.json

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
DEBUG_MODE=false


# ============================================
# LiveKit Configuration
# ============================================
LIVEKIT_URL=wss://voivrbot-mj7hi6ac.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_HTTP_PORT=8181
